{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "framework": null,
  "rewrites": [
    {
      "source": "/((?!assets/).*)",
      "destination": "/api/ssr"
    }
  ],
  "functions": {
    "api/ssr.mjs": {
      "includeFiles": "dist/**"
    }
  }
}
